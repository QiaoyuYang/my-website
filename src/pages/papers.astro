---
import Layout from "@/layouts/Layout.astro";
import { publications } from "@/data/cv";
import { highlightAuthor } from "@/lib/utils";
import { template } from "@/settings";

const PAPERS_PER_PAGE = 5;
const currentPage = Number(Astro.url.searchParams.get("page")) || 1;
const totalPages = Math.ceil(publications.length / PAPERS_PER_PAGE);
const paginatedPapers = publications.slice(
  (currentPage - 1) * PAPERS_PER_PAGE,
  currentPage * PAPERS_PER_PAGE
);

const prevHref = currentPage > 1 ? `?page=${currentPage - 1}` : "#";
const prevClass = `join-item btn btn-sm${currentPage === 1 ? " btn-disabled" : ""}`;
const nextHref = currentPage < totalPages ? `?page=${currentPage + 1}` : "#";
const nextClass = `join-item btn btn-sm${currentPage === totalPages ? " btn-disabled" : ""}`;
const pageLinks = Array.from({ length: totalPages }, (_, i) => ({
  page: i + 1,
  href: `?page=${i + 1}`,
  className: `join-item btn btn-sm${i + 1 === currentPage ? " btn-active" : ""}`,
}));
---

<Layout title="Papers">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Publications</h1>
    <div class="space-y-8">
      {paginatedPapers.map((paper) => (
        <div class="card bg-base-200">
          <div class="card-body">
            <h2 class="card-title text-xl">
              <a href={template.base + paper.link} class="hover:text-accent">
                {paper.title}
              </a>
            </h2>
            <p class="text-base mb-2">
              <span class="font-medium">Authors:</span>{" "}
              <span set:html={highlightAuthor(paper.authors)} />
            </p>
            <p class="text-sm mb-3">
              <span class="italic">{paper.journal}</span> • {paper.time}
            </p>
            <p class="text-sm text-base-content/80">{paper.abstract}</p>
            <div class="card-actions justify-end mt-4">
              <a href={paper.link} class="btn btn-sm btn-secondary text-secondary-content">
                Read Paper
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    {totalPages > 1 && (
      <div class="flex justify-center mt-8">
        <div class="join">
          <a href={prevHref} class={prevClass}>«</a>
          {pageLinks.map((link) => (
            <a href={link.href} class={link.className}>{link.page}</a>
          ))}
          <a href={nextHref} class={nextClass}>»</a>
        </div>
      </div>
    )}
  </div>
</Layout>